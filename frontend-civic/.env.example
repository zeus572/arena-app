# Backend API base URL for the civic app. Defaults to http://localhost:5050/api when unset.
VITE_CIVIC_API_URL=http://localhost:5050/api

# Debate/arena backend — owns identity (/auth/*, /profile/me). Defaults to
# http://localhost:5000/api when unset.
VITE_ARENA_API_URL=http://localhost:5000/api

# Android (Capacitor) builds MUST set both URLs explicitly — the bundle is
# served from https://localhost inside the WebView, so relative/localhost
# defaults don't reach a real backend. See docs/Android_Dev.md.
# For emulator dev with `adb reverse`, the localhost defaults above work as-is.
